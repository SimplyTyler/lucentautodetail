# Local app URL used for Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection string. Render injects this automatically from render.yaml.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lucentautodetail

# Generate a long random value for production. Render generates this automatically.
SESSION_SECRET=replace-with-a-long-random-secret

# Stripe sandbox keys. Never commit real values.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Comma-separated emails that should receive admin access.
ADMIN_EMAILS=owner@example.com
